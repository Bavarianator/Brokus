#!/usr/bin/env bash
# ─────────────────────────────────────────────────────────────
#  brokus – KI-Buchgenerator im Terminal
#
#  Auto-Setup bei erstem Aufruf:
#  1. Python-Dependencies installieren (PEP 668-sicher)
#  2. Symlink ~/.local/bin/brokus → bin/brokus erstellen
#  3. ~/.local/bin zum PATH hinzufügen (bashrc/zshrc)
#  4. App starten
#
#  Nach dem ersten Aufruf ist `brokus` global verfügbar.
# ─────────────────────────────────────────────────────────────

set -e

# ── Projektverzeichnis finden (funktioniert auch via Symlink) ──
SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/.." && pwd)"
PYTHON="${BROKUS_PYTHON:-python3}"
TARGET_DIR="${XDG_BIN_HOME:-$HOME/.local/bin}"
TARGET_LINK="$TARGET_DIR/brokus"

cd "$SCRIPT_DIR"

# ── rclone automatisch installieren (Cloud-Upload) ──
if ! command -v rclone &>/dev/null; then
    echo "📦 brokus: Installiere rclone (Cloud-Upload für 40+ Anbieter)..." >&2
    if [[ "$(uname)" == "Darwin" ]] && command -v brew &>/dev/null; then
        brew install rclone 2>&1 && echo "  ✓ rclone installiert (brew)" >&2
    elif command -v apt &>/dev/null; then
        sudo apt install -y rclone 2>&1 && echo "  ✓ rclone installiert (apt)" >&2
    elif command -v pacman &>/dev/null; then
        sudo pacman -S --noconfirm rclone 2>&1 && echo "  ✓ rclone installiert (pacman)" >&2
    elif command -v dnf &>/dev/null; then
        sudo dnf install -y rclone 2>&1 && echo "  ✓ rclone installiert (dnf)" >&2
    else
        echo "  ⚠ rclone nicht gefunden – Cloud-Upload via rclone benötigt es." >&2
        echo "  Installiere manuell: https://rclone.org/install/" >&2
    fi
fi

# ═════════════════════════════════════════════════════════════
#  1. Dependencies prüfen / installieren
# ═════════════════════════════════════════════════════════════

if ! "$PYTHON" -c "import rich" 2>/dev/null; then
    echo "📦 brokus: Installiere Python-Dependencies..." >&2

    if PIP_OUTPUT=$("$PYTHON" -m pip install -e . 2>&1); then
        echo "  ✓ Dependencies installiert" >&2
    elif echo "$PIP_OUTPUT" | grep -qi "externally-managed"; then
        echo "  ⚠ PEP 668 (Arch/Manjaro) – versuche mit --break-system-packages..." >&2
        if PIP_OUTPUT2=$("$PYTHON" -m pip install --break-system-packages -e . 2>&1); then
            echo "  ✓ Dependencies installiert" >&2
        else
            echo "  ✗ pip-install fehlgeschlagen:" >&2
            echo "$PIP_OUTPUT2" | head -3 >&2
            echo "  Manuell: cd $SCRIPT_DIR && pip install --break-system-packages -e ." >&2
            exit 1
        fi
    else
        echo "  ✗ pip-install fehlgeschlagen:" >&2
        echo "$PIP_OUTPUT" | head -3 >&2
        echo "  Manuell: cd $SCRIPT_DIR && pip install -e ." >&2
        exit 1
    fi
fi

# ═════════════════════════════════════════════════════════════
#  2. Symlink erstellen (falls nicht vorhanden)
# ═════════════════════════════════════════════════════════════

if [[ ! -L "$TARGET_LINK" && ! -f "$TARGET_LINK" ]]; then
    echo "  🔗 Erstelle Symlink: $TARGET_LINK → bin/brokus" >&2
    mkdir -p "$TARGET_DIR"
    ln -s "$SCRIPT_DIR/bin/brokus" "$TARGET_LINK"
fi

# ═════════════════════════════════════════════════════════════
#  3. PATH prüfen & Shell-Config aktualisieren (einmalig)
# ═════════════════════════════════════════════════════════════

if ! echo "$PATH" | tr ':' '\n' | grep -qx "$TARGET_DIR" 2>/dev/null; then
    SHELL_NAME="$(basename "${SHELL:-/bin/bash}")"
    case "$SHELL_NAME" in
        zsh)  RC="$HOME/.zshrc" ;;
        bash) RC="$HOME/.bashrc" ;;
        *)    for f in "$HOME/.profile" "$HOME/.bash_profile" "$HOME/.bashrc" "$HOME/.zshrc"; do
                  [[ -f "$f" ]] && { RC="$f"; break; }
              done
              [[ -z "$RC" ]] && RC="$HOME/.profile" ;;
    esac

    if ! grep -q "\.local/bin" "$RC" 2>/dev/null; then
        echo "  🔧 Füge ~/.local/bin zum PATH in $RC hinzu" >&2
        {
            echo ""
            echo "# brokus: lokale Binaries zum PATH hinzufügen"
            echo 'export PATH="$HOME/.local/bin:$PATH"'
        } >> "$RC"
    fi

    # PATH für diese Session setzen
    export PATH="$HOME/.local/bin:$PATH"
fi

# ═════════════════════════════════════════════════════════════
#  4. App starten
# ═════════════════════════════════════════════════════════════

exec "$PYTHON" -m brokus "$@"
